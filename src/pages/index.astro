---
const siteUrl = 'https://mixipos.com/'
const pageTitle = 'Restoran, Kafe ve Otel için POS & Adisyon Programı | mixipos'
const pageDescription =
  'Restoran, kafe, bar ve otel F&B için yapay zekâ destekli POS ve adisyon programı: QR ile self-servis sipariş, mutfak ekranı (KDS), oda folio entegrasyonu, akıllı stok ve canlı ciro takibi. Kurulum yok, tarayıcıdan çalışır.'
const ogImage = new URL('/assets/panel-screenshot.png', siteUrl).toString()
const logoImage = new URL('/assets/mixipos-logo.svg', siteUrl).toString()
const keywords = [
  'restoran pos programı',
  'adisyon programı',
  'qr sipariş',
  'qr menü',
  'kafe pos',
  'bar pos',
  'otel pos programı',
  'mutfak ekranı',
  'kds',
  'oda folyo entegrasyonu',
  'restoran adisyon programı',
  'garson el terminali',
  'hesap bölme',
  'z raporu',
  'restoran stok takibi',
  'dokunmatik pos',
  'çok şubeli pos',
  'yapay zeka pos'
]
const faqItems = [
  {
    question: 'Kurulum gerekiyor mu, hangi cihazlarda çalışır?',
    answer:
      'Kurulum yok. mixipos tarayıcıdan çalışır; tablet, telefon, dokunmatik POS terminali ve bilgisayarda aynı hesapla açılır.'
  },
  {
    question: 'QR sipariş için misafir uygulama indirir mi?',
    answer:
      'Hayır. Misafir masadaki QR kodu kamerasıyla okutur, menü tarayıcıda açılır ve sipariş verilir. İndirme veya üyelik gerekmez.'
  },
  {
    question: 'İnternet kesilirse ne olur?',
    answer:
      'Kısa bağlantı kesintilerinde açık adisyon ekranda kalır; bağlantı geri geldiğinde kayıtlar otomatik olarak eşitlenir.'
  },
  {
    question: 'Otel oda folyosuna nasıl bağlanır?',
    answer:
      'minirez veya maxirez kullanıyorsanız mixipos PMS ile entegredir; F&B adisyonunu tek tıkla misafirin odasına yazarsınız.'
  },
  {
    question: 'Hesap bölme ve kişi bazlı ödeme var mı?',
    answer:
      'Evet. Hesabı kişiye veya kaleme göre bölün, masaları birleştirin, her payı ayrı kartla veya nakitle tahsil edin.'
  },
  {
    question: 'Mutfak ekranı (KDS) ayrı bir cihaz mı?',
    answer:
      'Hayır, herhangi bir tablet veya ekran KDS’e döner. Siparişler gerçek zamanlı düşer; hazırlanıyor → hazır akışıyla yönetilir.'
  },
  {
    question: 'Ödeme ve POS cihazı entegrasyonu var mı?',
    answer:
      'iyzico ve PayTR ile online ödeme desteklenir; yerel banka POS cihazlarıyla uyumlu çalışır.'
  },
  {
    question: 'minirez, maxirez ve mixifin ile ilişkisi nedir?',
    answer:
      'Dördü de Adviceal ürünüdür ve aynı panel altyapısında çalışır. Oteli, acenteyi veya ön muhasebeyi zaten kullanıyorsanız mixipos’a aynı hesapla geçersiniz.'
  }
]
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#organization`,
      name: 'AdviceAl Online Danışmanlık Turizm Sanayi ve Ticaret Ltd. Şti.',
      url: 'https://adviceal.com/',
      telephone: '+90 242 606 19 91',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Akdeniz Üniversitesi Uluğbey Ar-Ge Binası No: 3A/5 Teknokent',
        addressLocality: 'Antalya',
        addressCountry: 'TR'
      },
      brand: {
        '@type': 'Brand',
        name: 'mixipos',
        url: siteUrl,
        logo: logoImage
      },
      sameAs: [
        'https://facebook.com/adviceal',
        'https://instagram.com/advicealcom',
        'https://linkedin.com/company/adviceal',
        'https://twitter.com/adviceal',
        'https://youtube.com/@adviceal'
      ]
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'mixipos',
      inLanguage: 'tr-TR',
      publisher: { '@id': `${siteUrl}#organization` }
    },
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}#webpage`,
      url: siteUrl,
      name: pageTitle,
      description: pageDescription,
      isPartOf: { '@id': `${siteUrl}#website` },
      about: { '@id': `${siteUrl}#software` },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: ogImage,
        width: 1200,
        height: 630
      },
      inLanguage: 'tr-TR'
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${siteUrl}#software`,
      name: 'mixipos',
      applicationCategory: 'BusinessApplication',
      applicationSubCategory: 'Point of Sale / Restaurant POS',
      operatingSystem: 'Web',
      url: siteUrl,
      image: ogImage,
      description: pageDescription,
      inLanguage: 'tr-TR',
      publisher: { '@id': `${siteUrl}#organization` },
      provider: { '@id': `${siteUrl}#organization` },
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'TRY',
        description: 'Ücretsiz canlı demo ve kurulum danışmanlığı'
      },
      featureList: [
        'AI akıllı dashboard: canlı ciro, anomali tespiti ve ciro tahmini',
        'QR ile self-servis sipariş (uygulama gerektirmez)',
        'Adisyon böl, birleştir, masa taşı ve kişi bazlı ödeme',
        'Mutfak ekranı (KDS) ve gerçek zamanlı sipariş akışı',
        'Otel oda folio entegrasyonu (PMS ile)',
        'Akıllı stok: otomatik düşüm, kritik stok uyarısı, fire/iade',
        'Kasa & vardiya yönetimi, Z-raporu, nakit-kart mutabakatı',
        'Denetim izi ve raporlar: garson performansı, ürün satış, iptal/void'
      ],
      audience: {
        '@type': 'BusinessAudience',
        audienceType: 'Restoran, kafe, bar, otel F&B, hızlı servis ve çok şubeli işletmeler'
      }
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}#faq`,
      url: `${siteUrl}#sss`,
      inLanguage: 'tr-TR',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer
        }
      }))
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${siteUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'mixipos',
          item: siteUrl
        }
      ]
    }
  ]
}
---

<html lang="tr">
<head>
  <!--
    Google Analytics (GA4) is intentionally OMITTED from the shipped page.
    To enable it, uncomment the block below and replace G-XXXXXXXXXX with this
    property's real Measurement ID (see .env.example). Never ship another
    property's id.

    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="keywords" content={keywords.join(', ')} />
  <meta name="author" content="Adviceal" />
  <meta name="publisher" content="Adviceal" />
  <meta name="application-name" content="mixipos" />
  <meta name="apple-mobile-web-app-title" content="mixipos" />
  <meta http-equiv="content-language" content="tr-TR" />
  <meta name="theme-color" content="#160b05" />
  <meta name="color-scheme" content="dark light" />
  <link rel="canonical" href={siteUrl} />
  <link rel="alternate" hreflang="tr-TR" href={siteUrl} />
  <link rel="alternate" hreflang="x-default" href={siteUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:site_name" content="mixipos" />
  <meta property="og:locale" content="tr_TR" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="mixipos restoran POS ve adisyon paneli" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content="mixipos restoran POS ve adisyon paneli" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css?v=2" />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</head>
<body>

  <div class="progress" id="progress" aria-hidden="true"></div>

  <!-- ====================== NAV ====================== -->
  <header class="nav" id="nav">
    <div class="container nav__inner">
      <a class="brand" href="#top" aria-label="mixipos ana sayfa">
        <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
          <defs>
            <linearGradient id="navmark" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0" stop-color="#ffb02e"/><stop offset=".52" stop-color="#ff7a00"/><stop offset="1" stop-color="#f24a0a"/>
            </linearGradient>
          </defs>
          <rect width="32" height="32" rx="8" fill="url(#navmark)" opacity=".16"/>
          <path d="M8.5 7H23.5V23L19.25 15L16 18.5L12.75 15L8.5 23V7Z" fill="none" stroke="url(#navmark)" stroke-width="2.1" stroke-linejoin="round" stroke-linecap="round"/>
          <path d="M11 9.6H21M11 11.5H21M11 13.4H16.5" fill="none" stroke="url(#navmark)" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
        <span class="brand__word">mixipos</span>
      </a>
      <nav class="nav__links" aria-label="Sayfa içi gezinme">
        <a href="#ozellikler">Özellikler</a>
        <a href="#qr-siparis">QR Sipariş</a>
        <a href="#mutfak">Mutfak</a>
        <a href="#oda-folio">Oda Folio</a>
        <a href="#ai-dashboard">AI</a>
        <a href="#sss">SSS</a>
      </nav>
      <div class="nav__cta">
        <a class="nav__phone" href="tel:+902426061991">
          <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path d="M6.6 3h3l1.5 4.2-2 1.5a13 13 0 0 0 6.2 6.2l1.5-2L21 14.4v3A2.6 2.6 0 0 1 18.4 20 15.4 15.4 0 0 1 4 5.6 2.6 2.6 0 0 1 6.6 3z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
          0242 606 19 91
        </a>
        <a class="btn btn--ghost btn--sm nav__login" href="https://app.mixipos.com/login">
          <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path d="M10 17l5-5-5-5M15 12H3M13.5 4H19a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-5.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Giriş Yap
        </a>
        <a class="btn btn--primary btn--sm btn--shine" href="#demo">Ücretsiz Demo</a>
      </div>
      <button class="nav__burger" id="burger" aria-label="Menüyü aç" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="nav__sheet" id="navSheet">
      <a href="#ozellikler">Özellikler</a>
      <a href="#qr-siparis">QR Sipariş</a>
      <a href="#mutfak">Mutfak</a>
      <a href="#oda-folio">Oda Folio</a>
      <a href="#ai-dashboard">AI</a>
      <a href="#sss">SSS</a>
      <a href="tel:+902426061991">0242 606 19 91</a>
      <a class="btn btn--ghost" href="https://app.mixipos.com/login">Giriş Yap</a>
      <a class="btn btn--primary" href="#demo">Ücretsiz Demo</a>
    </div>
  </header>

  <main id="top">

    <!-- ====================== HERO ====================== -->
    <section class="hero" id="hero">
      <div class="hero__sky" aria-hidden="true">
        <div class="aurora aurora--1"></div>
        <div class="aurora aurora--2"></div>
        <div class="aurora aurora--3"></div>
        <div class="hero__grid"></div>
        <div class="hero__horizon"></div>
      </div>

      <div class="container hero__inner">
        <div class="hero__copy reveal">
          <a class="chip chip--hero" href="#aile">
            <span class="chip__dot"></span>
            Yeni · Adviceal ailesinin POS&apos;u
            <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M6 3.5 10.5 8 6 12.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>

          <h1 class="hero__title">
            Siparişten ödemeye,<br/>restoranınızın <span class="grad-text">akıllı POS&apos;u.</span>
          </h1>

          <p class="hero__sub">
            QR ile self-servis sipariş, mutfak ekranı, hesap bölme ve oda folio entegrasyonu —
            restoran, kafe, bar ve otel F&amp;B için yapay zekâ destekli adisyon. Kurulum yok,
            tarayıcıdan çalışır; gerisini <strong>mixipos</strong> halleder.
          </p>

          <div class="hero__actions">
            <a class="btn btn--primary btn--lg btn--shine" href="#demo">Ücretsiz Demo</a>
            <a class="btn btn--ghost btn--lg" href="#ozellikler">Özellikleri Gör</a>
          </div>

          <ul class="hero__trust" aria-label="Güven unsurları">
            <li>Kurulum yok, tarayıcıdan çalışır</li>
            <li>QR menü TR/EN</li>
            <li>iyzico &amp; PayTR ile ödeme</li>
            <li>7/24 canlı senkron</li>
          </ul>
        </div>

        <!-- ---------- Animated POS dashboard mockup ---------- -->
        <div class="hero__visual reveal" id="mock">
          <div class="mock" id="mockCard">
            <div class="mock__chrome">
              <span class="mock__dot" style="background:#fb7185"></span>
              <span class="mock__dot" style="background:#ffb02e"></span>
              <span class="mock__dot" style="background:#34d399"></span>
              <span class="mock__url">panel.mixipos.com</span>
            </div>
            <div class="mock__body">
              <aside class="mock__side">
                <div class="mock__sidebrand">mixipos</div>
                <div class="mock__sideitem is-active">Panel</div>
                <div class="mock__sideitem">Adisyonlar</div>
                <div class="mock__sideitem">Masalar</div>
                <div class="mock__sideitem">Mutfak (KDS)</div>
                <div class="mock__sideitem">QR Sipariş</div>
                <div class="mock__sideitem">Stok</div>
                <div class="mock__sideitem">Kasa &amp; Vardiya</div>
                <div class="mock__sideitem">Raporlar</div>
                <div class="mock__sideitem mock__sideitem--ai">Asistan <span>AI</span></div>
              </aside>
              <div class="mock__main">
                <div class="mock__head">
                  <div>
                    <div class="mock__title">Panel</div>
                    <div class="mock__subtitle">Canlı servis · bugün</div>
                  </div>
                  <div class="mock__pills">
                    <span class="is-on">Bugün</span><span>Hafta</span><span>Ay</span>
                  </div>
                </div>

                <div class="mock__cards">
                  <div class="kpi">
                    <span class="kpi__label">Günün cirosu</span>
                    <span class="kpi__value">₺<span class="count" data-count="128480">0</span></span>
                    <span class="kpi__delta kpi__delta--up">▲ %14</span>
                  </div>
                  <div class="kpi">
                    <span class="kpi__label">Sipariş</span>
                    <span class="kpi__value"><span class="count" data-count="842">0</span></span>
                    <span class="kpi__delta kpi__delta--up">▲ %9</span>
                  </div>
                  <div class="kpi">
                    <span class="kpi__label">Ortalama adisyon</span>
                    <span class="kpi__value">₺<span class="count" data-count="152">0</span></span>
                    <span class="kpi__delta kpi__delta--up">▲ %6</span>
                  </div>
                  <div class="kpi">
                    <span class="kpi__label">Açık masa</span>
                    <span class="kpi__value kpi__value--ok"><span class="count" data-count="14">0</span></span>
                    <span class="kpi__delta">şu an</span>
                  </div>
                </div>

                <div class="mock__chartcard">
                  <div class="mock__chartcard-head">
                    <span>Saatlik ciro &amp; sipariş</span>
                    <div class="mock__toggle" role="group" aria-label="Grafik aralığı">
                      <button class="is-on" id="tglToday" type="button">Bugün</button>
                      <button id="tglWeek" type="button">Hafta</button>
                    </div>
                  </div>
                  <div class="mock__legend">
                    <span><i class="lg lg--line"></i>Kümülatif ciro</span>
                    <span><i class="lg lg--card"></i>Kart</span>
                    <span><i class="lg lg--in"></i>Nakit</span>
                  </div>
                  <svg id="flowChart" viewBox="0 0 560 190" preserveAspectRatio="none" aria-label="Saatlik ciro ve ödeme grafiği">
                    <defs>
                      <linearGradient id="areaFill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0" stop-color="#ff7a00" stop-opacity=".32"/>
                        <stop offset="1" stop-color="#ff7a00" stop-opacity="0"/>
                      </linearGradient>
                      <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
                        <stop offset="0" stop-color="#ffb02e"/><stop offset=".6" stop-color="#ff7a00"/><stop offset="1" stop-color="#f24a0a"/>
                      </linearGradient>
                    </defs>
                    <g id="flowGrid"></g>
                    <g id="flowBars"></g>
                    <path id="flowArea" fill="url(#areaFill)" d=""></path>
                    <path id="flowLine" fill="none" stroke="url(#lineGrad)" stroke-width="3" stroke-linecap="round" d=""></path>
                    <g id="flowDots"></g>
                  </svg>
                  <div class="mock__xlabels" id="xLabels"></div>
                </div>

                <div class="mock__row2">
                  <div class="mock__barcard">
                    <span class="mock__barcard-title">Kategori satışları <em>(bugün)</em></span>
                    <div class="catbars" id="catBars" aria-hidden="true"></div>
                  </div>
                  <div class="mock__agingcard">
                    <span class="mock__barcard-title">Ödeme dağılımı</span>
                    <div class="donutwrap">
                      <svg class="donut" id="donut" viewBox="0 0 140 140" aria-hidden="true">
                        <circle class="donut__bg" cx="70" cy="70" r="54"></circle>
                        <g id="donutSegs"></g>
                      </svg>
                      <div class="donut__legend">
                        <div><i style="background:#ff7a00"></i>Kart <b>%56</b></div>
                        <div><i style="background:#34d399"></i>Nakit <b>%22</b></div>
                        <div><i style="background:#ffc24d"></i>Yemek kartı <b>%12</b></div>
                        <div><i style="background:#f24a0a"></i>Oda folio <b>%10</b></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- floating cards -->
          <div class="float float--order" aria-hidden="true">
            <div class="float__icon float__icon--ai">QR</div>
            <div>
              <strong>Yeni QR siparişi · Masa 7</strong>
              <p>3 ürün · mutfağa düştü <span>Onayla →</span></p>
            </div>
          </div>
          <div class="float float--folio" aria-hidden="true">
            <div class="float__icon float__icon--ok">✓</div>
            <div>
              <strong>Oda 214&apos;e yazıldı</strong>
              <p>Bar adisyonu ₺840 · PMS folio</p>
            </div>
          </div>
          <div class="float float--kds" aria-hidden="true">
            🍳 <b>Mutfak:</b> Masa 3 hazır
          </div>
        </div>
      </div>
    </section>

    <!-- ====================== MARQUEE ====================== -->
    <div class="marquee" aria-hidden="true">
